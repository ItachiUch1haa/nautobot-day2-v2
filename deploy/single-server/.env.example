# Copy to .env and change every value below before bringing this up anywhere
# reachable — these defaults are test-only and are not secret.

NAUTOBOT_SECRET_KEY=change-me-to-a-random-50-char-string
NAUTOBOT_DB_PASSWORD=change-me
NAUTOBOT_REDIS_PASSWORD=change-me

NAUTOBOT_SUPERUSER_NAME=admin
NAUTOBOT_SUPERUSER_EMAIL=admin@example.com
NAUTOBOT_SUPERUSER_PASSWORD=change-me
NAUTOBOT_SUPERUSER_API_TOKEN=change-me-generate-a-random-40-char-hex-token
